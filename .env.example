# Copy to .env and fill in your NYT app key from https://developer.nytimes.com/my-apps
# The CLI auto-loads .env from the current directory (or any parent).
# Only the Key is needed for the public REST APIs; the Secret is unused.
NYT_KEY=your-nyt-app-key-here
NYT_SECRET=your-nyt-app-secret-here

# Alternatively the canonical variable name also works:
# NYT_API_KEY=your-nyt-app-key-here

# Required only for `nyt read` (full article text), which fetches from
# nytimes.com directly rather than the APIs. Copy from your browser via
# DevTools -> Application -> Cookies; must include the NYT-S and datadome values.
NYT_COOKIE=NYT-S=...; nyt-a=...; datadome=...
